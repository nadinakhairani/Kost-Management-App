# Environment Variables untuk Netlify + Supabase
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke Git!

# ============================================================
# SUPABASE CONFIGURATION
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# URL project Supabase kamu (Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key (bukan anon key!) — dipakai di server-side / functions
# RAHASIA — jangan ekspos ke frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ============================================================
# SERVER CONFIGURATION (untuk development lokal saja)
# ============================================================
PORT=3000
